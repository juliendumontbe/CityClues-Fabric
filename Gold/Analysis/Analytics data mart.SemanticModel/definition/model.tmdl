model Model
	culture: en-US
	defaultPowerBIDataSourceVersion: powerBI_V3
	sourceQueryCulture: en-US
	dataAccessOptions
		legacyRedirects
		returnErrorValuesAsNull

annotation PBI_QueryOrder = ["DirectLake - wh_gold"]

annotation __PBI_TimeIntelligenceEnabled = 1

annotation PBI_ProTooling = ["DirectLakeOnOneLakeInWeb","WebModelingEdit"]

ref table fact_game_session
ref table city_difficulty_history
ref table city_difficulty
ref table weather_city_current_gold
ref table dim_city_gold
ref table dim_country_gold
ref table dim_calendar
ref table dim_data_origin
ref table hint_performance
ref table fact_hint_usage
ref table dim_hint_gold

