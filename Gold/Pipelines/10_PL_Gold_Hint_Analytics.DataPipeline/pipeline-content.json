      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "DROP TABLE IF EXISTS dbo.hint_performance;\n\nCREATE TABLE dbo.hint_performance (\n    hint_id INT,\n    hint_label VARCHAR(255),\n    hint_stage INT,\n    total_requested INT,\n    total_shown INT,\n    avg_guesses_after_hint DECIMAL(10,2),\n    success_after_hint_rate DECIMAL(10,4),\n    event_source VARCHAR(50),\n    is_simulated BIT\n);\n\nINSERT INTO dbo.hint_performance (\n    hint_id,\n    hint_label,\n    hint_stage,\n    total_requested,\n    total_shown,\n    avg_guesses_after_hint,\n    success_after_hint_rate,\n    event_source,\n    is_simulated\n)\nSELECT \n    dh.hint_id,\n    dh.hint_label,\n    dh.hint_stage,\n    COUNT(*) AS total_requested,\n    COUNT(*) AS total_shown,\n    CAST(AVG(fh.guesses_after_hint * 1.0) AS DECIMAL(10,2)) AS avg_guesses_after_hint,\n    CAST(AVG(fh.is_session_success * 1.0) AS DECIMAL(10,4)) AS success_after_hint_rate,\n    fh.event_source,\n    fh.is_simulated\nFROM [wh_gold].[dbo].[fact_hint_usage] fh\nJOIN [wh_gold].[dbo].[dim_hint_gold] dh\n    ON fh.hint_id = dh.hint_id\nGROUP BY \n    dh.hint_id,\n    dh.hint_label,\n    dh.hint_stage, \n    fh.event_source,\n    fh.is_simulated;",
                "type": "Expression"
              },
              "type": "Query"
            }
          ],
          "scriptBlockExecutionTimeout": "02:00:00"
        },
