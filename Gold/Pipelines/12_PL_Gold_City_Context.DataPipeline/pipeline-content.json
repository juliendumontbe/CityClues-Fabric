      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "TRUNCATE TABLE dbo.city_game_context;\n\nWITH difficulty_pivot AS (\n    SELECT\n        city_id,\n        MAX(difficulty_initial) AS difficulty_initial,\n\n        MAX(CASE \n            WHEN event_source = 'simulated_generator' AND is_simulated = 1\n            THEN difficulty_score\n        END) AS difficulty_simulated,\n\n        MAX(CASE \n            WHEN event_source = 'game_app' AND is_simulated = 0\n            THEN difficulty_score\n        END) AS difficulty_real,\n\n        MAX(CASE \n            WHEN event_source = 'simulated_generator' AND is_simulated = 1\n            THEN nb_sessions\n        END) AS nb_sessions_simulated,\n\n        MAX(CASE \n            WHEN event_source = 'game_app' AND is_simulated = 0\n            THEN nb_sessions\n        END) AS nb_sessions_real\n    FROM dbo.city_difficulty\n    GROUP BY city_id\n)\n\nINSERT INTO dbo.city_game_context (\n    city_id,\n    city_name,\n    hemisphere,\n    global_quadrant,\n    longitudinal_zone,\n    is_capital,\n    coastal_distance_category,\n    altitude_category,\n    city_category,\n    city_name_length_category,\n    city_word_count_category,\n    city_first_letter,\n    city_last_letter,\n    continent,\n    country_name,\n    country_density_category,\n    country_category,\n    languages_count,\n    currency_name,\n    neighbours_count,\n    temperature,\n    weather_type,\n    timezone_offset_sec,\n    utc_offset_hours,\n    is_weather_available,\n    is_local_time_available,\n    difficulty_initial,\n    difficulty_simulated,\n    difficulty_real,\n    difficulty_score_default,\n    nb_sessions_simulated,\n    nb_sessions_real\n)\nSELECT \n    sel.city_id,\n    ci.city_name,\n    ci.hemisphere,\n    ci.global_quadrant,\n    ci.longitudinal_zone,\n    ci.is_capital,\n    ci.coastal_distance_category,\n    ci.altitude_category,\n    ci.city_category,\n    ci.city_name_length_category,\n    ci.city_word_count_category,\n    ci.city_first_letter,\n    ci.city_last_letter,\n    co.continent,\n    co.country_name,\n    co.country_density_category,\n    co.country_category,\n    co.languages_count,\n    co.currency_name,\n    co.neighbours_count,\n    we.temperature,\n    we.weather_type,\n    we.timezone_offset_sec,\n    CASE\n        WHEN we.timezone_offset_sec IS NOT NULL\n        THEN CAST(we.timezone_offset_sec / 3600.0 AS DECIMAL(4,1))\n        ELSE NULL\n    END AS utc_offset_hours,\n    CASE \n        WHEN we.temperature IS NOT NULL\n         AND we.weather_type IS NOT NULL\n        THEN CAST(1 AS BIT)\n        ELSE CAST(0 AS BIT)\n    END AS is_weather_available,\n    CASE \n        WHEN we.timezone_offset_sec IS NOT NULL\n        THEN CAST(1 AS BIT)\n        ELSE CAST(0 AS BIT)\n    END AS is_local_time_available,\n    dp.difficulty_initial,\n    dp.difficulty_simulated,\n    dp.difficulty_real,\n    dp.difficulty_simulated AS difficulty_score_default,\n    dp.nb_sessions_simulated,\n    dp.nb_sessions_real\nFROM dbo.cities_selection_gold sel\nJOIN dbo.dim_city_gold ci\n    ON CAST(sel.city_id AS BIGINT) = ci.city_id\nJOIN dbo.dim_country_gold co\n    ON ci.country_code = co.country_code\nLEFT JOIN dbo.weather_city_current_gold we\n    ON we.city_id = CAST(sel.city_id AS BIGINT)\nLEFT JOIN difficulty_pivot dp\n    ON dp.city_id = CAST(sel.city_id AS BIGINT);",
                "type": "Expression"
              },
              "type": "Query"
            }
          ],
          "scriptBlockExecutionTimeout": "02:00:00"
        },
