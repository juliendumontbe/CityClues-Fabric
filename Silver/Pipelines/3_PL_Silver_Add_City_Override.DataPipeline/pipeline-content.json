      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "SELECT\n    dc.city_id,\n    dc.city_name,\n    dc.country_code,\n    dc.city_pop,\n    dc.is_capital,\n    dc.city_score,\n    CASE \n        WHEN cs.city_id IS NOT NULL THEN 'Y'\n        ELSE 'N'\n    END AS already_in_selection,\n    cs.selection_source\nFROM dbo.dim_city dc\nLEFT JOIN dbo.cities_selection_view cs\n    ON dc.city_id = cs.city_id\nWHERE dc.city_id = @{pipeline().parameters.p_city_id};",
                "type": "Expression"
              },
              "type": "Query"
            }
          ],
          "scriptBlockExecutionTimeout": "02:00:00"
        },
        "connectionSettings": {
          "name": "wh_silver",
