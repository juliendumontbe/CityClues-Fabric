      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "INSERT INTO dbo.city_selection_overrides (\r\n    city_id,\r\n    is_active,\r\n    override_reason,\r\n    added_by,\r\n    added_at\r\n)\r\nSELECT\r\n    dc.city_id,\r\n    1,\r\n    'Demo live - manual update',\r\n    'Julien',\r\n    CAST(SYSDATETIME() AS DATETIME2(6))\r\nFROM dbo.dim_city dc\r\nWHERE dc.city_id = @{pipeline().parameters.p_city_id}\r\n  AND NOT EXISTS (\r\n      SELECT 1\r\n      FROM dbo.city_selection_overrides o\r\n      WHERE o.city_id = dc.city_id\r\n        AND o.is_active = 1\r\n  );",
                "type": "Expression"
              },
              "type": "Query"
            }
          ],
          "scriptBlockExecutionTimeout": "02:00:00"
        },
