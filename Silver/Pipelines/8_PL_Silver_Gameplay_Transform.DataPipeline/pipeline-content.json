      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "TRUNCATE TABLE [wh_silver].[dbo].[game_session];\nINSERT INTO [wh_silver].[dbo].[game_session] (\n    session_id,\n    city_id,\n    session_start_ts,\n    session_end_ts,\n    session_duration_sec,\n    session_status,\n    session_result,\n    difficulty_at_start,\n    nb_hints_requested,\n    nb_hints_shown,\n    event_source,\n    is_simulated\n)\nSELECT\n    session_id,\n    MAX(city_id) AS city_id,\n    MIN(event_ts) AS session_start_ts,\n    MAX(event_ts) AS session_end_ts,\n    DATEDIFF(SECOND, MIN(event_ts), MAX(event_ts)) AS session_duration_sec,\n    CASE\n        WHEN MAX(CASE WHEN event_type = 'abandoned' THEN 1 ELSE 0 END) = 1 THEN 'abandoned'\n        WHEN MAX(CASE WHEN event_type = 'session_ended' THEN 1 ELSE 0 END) = 1 THEN 'completed'\n        ELSE 'in_progress'\n    END AS session_status,\n    MAX(session_result) AS session_result,\n    MAX(CASE \n        WHEN event_type = 'session_started' THEN difficulty_at_start\n        ELSE NULL \n    END) AS difficulty_at_start,\n    SUM(CASE WHEN event_type = 'hint_requested' THEN 1 ELSE 0 END) AS nb_hints_requested,\n    SUM(CASE WHEN event_type = 'hint_shown' THEN 1 ELSE 0 END) AS nb_hints_shown,\n    CASE\n        WHEN COUNT(DISTINCT event_source) = 1 THEN MAX(event_source)\n        ELSE 'mixed'\n    END AS event_source,\n    MAX(CAST(is_simulated AS INT)) AS is_simulated\nFROM [lh_silver].[dbo].[Game_event_clean]\nGROUP BY session_id;",
                "type": "Expression"
              },
              "type": "Query"
            }
          ],
