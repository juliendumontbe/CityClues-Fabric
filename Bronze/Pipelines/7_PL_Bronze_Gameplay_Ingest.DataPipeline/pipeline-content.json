      {
        "type": "Script",
        "typeProperties": {
          "scripts": [
            {
              "text": {
                "value": "IF OBJECT_ID('dbo.game_event_raw_real', 'U') IS NULL\nBEGIN\n    CREATE TABLE dbo.game_event_raw_real (\n        firestore_doc_id VARCHAR(100),\n        event_source VARCHAR(50),\n        session_id VARCHAR(100),\n        city_id BIGINT,\n        is_simulated INT,\n        event_sequence INT,\n        event_ts VARCHAR(30),\n        event_type VARCHAR(100),\n        event_id VARCHAR(100),\n        hint_id BIGINT,\n        payload_guess_text VARCHAR(500),\n        payload_is_correct INT,\n        payload_session_result VARCHAR(50),\n        payload_hint_stage INT,\n        payload_response_time_sec INT,\n        payload_difficulty_at_start DECIMAL(10,3)\n    );\nEND;\n\n\n\nIF OBJECT_ID('dbo.game_event_raw_simulated', 'U') IS NULL\nBEGIN\n    CREATE TABLE dbo.game_event_raw_simulated (\n        firestore_doc_id VARCHAR(100),\n        event_source VARCHAR(50),\n        session_id VARCHAR(100),\n        city_id BIGINT,\n        is_simulated INT,\n        event_sequence INT,\n        event_ts VARCHAR(30),\n        event_type VARCHAR(100),\n        event_id VARCHAR(100),\n        hint_id BIGINT,\n        payload_guess_text VARCHAR(500),\n        payload_is_correct INT,\n        payload_session_result VARCHAR(50),\n        payload_hint_stage INT,\n        payload_response_time_sec INT,\n        payload_difficulty_at_start DECIMAL(10,3)\n    );\nEND;",
                "type": "Expression"
              },
              "type": "Query"
            }
          ],
          "scriptBlockExecutionTimeout": "02:00:00"
        },
